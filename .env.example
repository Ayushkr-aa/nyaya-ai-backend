# Nyaya AI: Backend Environment Variables
# Copy these from local into your Render/Vercel dashboard secrets!

# Google Gemini API Key (Obtain from https://aistudio.google.com/)
GEMINI_API_KEY=your_api_key_here

# Mode Settings (Set to 'false' for free cloud tiers like Render)
USE_LOCAL_MODEL=false

# Vector Database Path (Defaults to ./chroma_db)
CHROMA_PERSIST_DIR=./chroma_db

# LLM & Embedding Models
LLM_MODEL=gemini-1.5-flash
EMBEDDING_MODEL=models/text-embedding-004

# To bypass the LLM and return Kaggle dataset content directly (fixes Gemini rate limits)
USE_LLM=true
